{
  "name": "coinchain",
  "version": "0.1.0",
  "private": true,
  "author": "Coin Chain",
  "description": "Coin Chain desktop game foundation",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:desktop\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:desktop": "wait-on tcp:5173 && npm run build:desktop && cross-env COIN_CHAIN_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:desktop",
    "build:renderer": "vite build",
    "build:desktop": "tsc -p tsconfig.electron.json",
    "dist:win": "npm run build && electron-builder --win portable",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json"
  },
  "build": {
    "appId": "com.coinchain.desktop",
    "productName": "Coin Chain",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "Coin-Chain-${version}.${ext}"
    }
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "wait-on": "^8.0.5"
  }
}
